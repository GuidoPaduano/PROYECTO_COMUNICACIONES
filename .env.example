DJANGO_SECRET_KEY=changeme
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
# En desarrollo local, si omitis DATABASE_URL se usa db.sqlite3 automaticamente.
# DATABASE_URL=postgresql://usuario:password@host:puerto/dbname

# Resend (email delivery)
RESEND_API_KEY=changeme
RESEND_FROM_EMAIL=noreply@alumnix.com.ar

# Frontend (links de reset)
FRONTEND_BASE_URL=http://localhost:3000
PASSWORD_RESET_PATH=/reset-password

# JWT
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
JWT_COOKIE_SECURE=False
JWT_COOKIE_SAMESITE=Lax
LOGIN_THROTTLE_RATE=10/min
STUDENT_IMPORT_MAX_BYTES=5242880

# CORS/CSRF (opcionales en dev, REQUERIDOS en prod)
# CORS_ALLOWED_ORIGINS=http://localhost:3000
# CSRF_TRUSTED_ORIGINS=https://tu-proyecto.up.railway.app,http://localhost:3000
# LAN_ORIGIN=http://192.168.1.38:3000  # IP LAN para desarrollo desde otros dispositivos
# En producción agregar el dominio de Railway a ALLOWED_HOSTS:
# ALLOWED_HOSTS=tu-proyecto.up.railway.app,localhost,127.0.0.1

# QA local seed
QA_DEFAULT_PASSWORD=QaLocal123!
QA_SCHOOL_SLUG=qa-local
QA_PLATFORM_ADMIN_USERNAME=qa_platform_admin
QA_SCHOOL_ADMIN_USERNAME=qa_school_admin
QA_DIRECTIVO_USERNAME=qa_directivo
QA_PROFESOR_USERNAME=qa_profesor
QA_PRECEPTOR_USERNAME=qa_preceptor
QA_PADRE_USERNAME=qa_padre
QA_ALUMNO_USERNAME=qa_alumno
